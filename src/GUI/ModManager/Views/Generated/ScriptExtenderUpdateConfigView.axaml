<!--auto-generated-->
<UserControl
	x:Class="ModManager.Views.Generated.ScriptExtenderUpdateConfigView"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:manager="using:ModManager"
	xmlns:controls="using:ModManager.Controls"
	xmlns:vm="using:ModManager.Models.Settings"
	x:DataType="vm:ScriptExtenderUpdateConfig"
	d:DesignHeight="900"
    d:DesignWidth="1600"
	mc:Ignorable="d">
	<Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" Grid.IsSharedSizeScope="True">
		<TextBlock x:Name="UpdateChannelTextBlock" Grid.Row="0" Grid.Column="0" Classes="left" Text="{manager:LocaleKey Settings_ExtenderUpdater_UpdateChannel}" ToolTip.Tip="{manager:LocaleKey Settings_ExtenderUpdater_UpdateChannel_ToolTip}" />
		<ComboBox x:Name="UpdateChannelComboBox" Grid.Row="0" Grid.Column="1" Classes="right" SelectedIndex="{Binding UpdateChannelIndex, FallbackValue=0}" ToolTip.Tip="{manager:LocaleKey Settings_ExtenderUpdater_UpdateChannel_ToolTip}">
			<ComboBoxItem Content="{manager:LocaleKey ExtenderUpdateChannel_Release}" ToolTip.Tip="{manager:LocaleKey ExtenderUpdateChannel_Release_ToolTip}" Tag="Release" />
			<ComboBoxItem Content="{manager:LocaleKey ExtenderUpdateChannel_Devel}" ToolTip.Tip="{manager:LocaleKey ExtenderUpdateChannel_Devel_ToolTip}" Tag="Devel" />
			<ComboBoxItem Content="{manager:LocaleKey ExtenderUpdateChannel_Nightly}" ToolTip.Tip="{manager:LocaleKey ExtenderUpdateChannel_Nightly_ToolTip}" Tag="Nightly" />
		</ComboBox>
		
		<TextBlock x:Name="CachePathTextBlock" Grid.Row="1" Grid.Column="0" Classes="left" Text="{manager:LocaleKey Settings_ExtenderUpdater_CachePath}" IsVisible="{Binding DevOptionsEnabled}" />
		<controls:EnhancedTextBox x:Name="CachePathTextBox" Grid.Row="1" Grid.Column="1" Classes="compact" Text="{Binding CachePath, UpdateSourceTrigger=LostFocus}" IsVisible="{Binding DevOptionsEnabled}"/>
		
		<TextBlock x:Name="DebugTextBlock" Grid.Row="2" Grid.Column="0" Classes="left" Text="{manager:LocaleKey Settings_ExtenderUpdater_Debug}" ToolTip.Tip="{manager:LocaleKey Settings_ExtenderUpdater_Debug_ToolTip}" />
		<CheckBox x:Name="DebugCheckBox" Grid.Row="2" Grid.Column="1" Classes="right" IsChecked ="{Binding Debug}" ToolTip.Tip="{manager:LocaleKey Settings_ExtenderUpdater_Debug_ToolTip}"/>
		
		<TextBlock x:Name="DisableUpdatesTextBlock" Grid.Row="3" Grid.Column="0" Classes="left" Text="{manager:LocaleKey Settings_ExtenderUpdater_DisableUpdates}" ToolTip.Tip="{manager:LocaleKey Settings_ExtenderUpdater_DisableUpdates_ToolTip}" />
		<CheckBox x:Name="DisableUpdatesCheckBox" Grid.Row="3" Grid.Column="1" Classes="right" IsChecked ="{Binding DisableUpdates}" ToolTip.Tip="{manager:LocaleKey Settings_ExtenderUpdater_DisableUpdates_ToolTip}"/>
		
		<TextBlock x:Name="IPv4OnlyTextBlock" Grid.Row="4" Grid.Column="0" Classes="left" Text="{manager:LocaleKey Settings_ExtenderUpdater_IPv4Only}" ToolTip.Tip="{manager:LocaleKey Settings_ExtenderUpdater_IPv4Only_ToolTip}" />
		<CheckBox x:Name="IPv4OnlyCheckBox" Grid.Row="4" Grid.Column="1" Classes="right" IsChecked ="{Binding IPv4Only}" ToolTip.Tip="{manager:LocaleKey Settings_ExtenderUpdater_IPv4Only_ToolTip}"/>
		
		<TextBlock x:Name="ManifestNameTextBlock" Grid.Row="5" Grid.Column="0" Classes="left" Text="{manager:LocaleKey Settings_ExtenderUpdater_ManifestName}" IsVisible="{Binding DevOptionsEnabled}" />
		<controls:EnhancedTextBox x:Name="ManifestNameTextBox" Grid.Row="5" Grid.Column="1" Classes="compact" Text="{Binding ManifestName, UpdateSourceTrigger=LostFocus}" IsVisible="{Binding DevOptionsEnabled}"/>
		
		<TextBlock x:Name="ManifestURLTextBlock" Grid.Row="6" Grid.Column="0" Classes="left" Text="{manager:LocaleKey Settings_ExtenderUpdater_ManifestURL}" IsVisible="{Binding DevOptionsEnabled}" />
		<controls:EnhancedTextBox x:Name="ManifestURLTextBox" Grid.Row="6" Grid.Column="1" Classes="compact" Text="{Binding ManifestURL, UpdateSourceTrigger=LostFocus}" IsVisible="{Binding DevOptionsEnabled}"/>
		
		<TextBlock x:Name="TargetResourceDigestTextBlock" Grid.Row="7" Grid.Column="0" Classes="left" Text="{manager:LocaleKey Settings_ExtenderUpdater_TargetResourceDigest}" ToolTip.Tip="{manager:LocaleKey Settings_ExtenderUpdater_TargetResourceDigest_ToolTip}" IsVisible="{Binding DevOptionsEnabled}" />
		<controls:EnhancedTextBox x:Name="TargetResourceDigestTextBox" Grid.Row="7" Grid.Column="1" Classes="compact" Text="{Binding TargetResourceDigest, UpdateSourceTrigger=LostFocus}" ToolTip.Tip="{manager:LocaleKey Settings_ExtenderUpdater_TargetResourceDigest_ToolTip}" IsVisible="{Binding DevOptionsEnabled}"/>
		
		<TextBlock x:Name="TargetVersionTextBlock" Grid.Row="8" Grid.Column="0" Classes="left" Text="{manager:LocaleKey Settings_ExtenderUpdater_TargetVersion}" ToolTip.Tip="{manager:LocaleKey Settings_ExtenderUpdater_TargetVersion_ToolTip}" />
		<controls:EnhancedTextBox x:Name="TargetVersionTextBox" Grid.Row="8" Grid.Column="1" Classes="compact" Text="{Binding TargetVersion, UpdateSourceTrigger=LostFocus}" ToolTip.Tip="{manager:LocaleKey Settings_ExtenderUpdater_TargetVersion_ToolTip}"/>
		
		<TextBlock x:Name="ValidateSignatureTextBlock" Grid.Row="9" Grid.Column="0" Classes="left" Text="{manager:LocaleKey Settings_ExtenderUpdater_ValidateSignature}" IsVisible="{Binding DevOptionsEnabled}" />
		<CheckBox x:Name="ValidateSignatureCheckBox" Grid.Row="9" Grid.Column="1" Classes="right" IsChecked ="{Binding ValidateSignature}" IsVisible="{Binding DevOptionsEnabled}"/>
	</Grid>
</UserControl>