<UserControl x:Class="ModManager.Views.Mods.ModContainerEntryView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:ModManager.Models.Mod"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:ModContainer"
    mc:Ignorable="d">
	<UserControl.Styles>
		<Style Selector="TextBlock">
			<Style Selector="^:pointerover">
				<Setter Property="Foreground" Value="{DynamicResource ModListHoveredTextForeground}" />
			</Style>
		</Style>
	</UserControl.Styles>
	<TextBlock VerticalAlignment="Center" Text="{Binding DisplayName}" TextAlignment="Left" />
</UserControl>